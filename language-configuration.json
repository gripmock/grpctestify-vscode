{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "'",
      "close": "'"
    },
    {
      "open": "\"",
      "close": "\""
    }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["'", "'"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(\\{.*|\\[.*|\\().*$",
    "decreaseIndentPattern": "^\\s*(\\}|\\]|\\)).*$"
  },
  "folding": {
    "markers": {
      "start": "^\\s*---\\s*(ADDRESS|ENDPOINT|REQUEST|RESPONSE|ERROR|REQUEST_HEADERS|ASSERTS|EXTRACT|TLS|PROTO|OPTIONS|HEADERS)\\b.*---\\s*$",
      "end": "(?=^---\\s*(ADDRESS|ENDPOINT|REQUEST|RESPONSE|ERROR|REQUEST_HEADERS|ASSERTS|EXTRACT|TLS|PROTO|OPTIONS|HEADERS)\\b.*---\\s*$|\\z)"
    }
  }
}
