{
  "scopeName": "source.grpctestify",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#sections"
    }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "match": "\\s*#.*$",
          "name": "comment.line.number-sign.grpctestify"
        },
        {
          "match": "\\s*//.*$",
          "name": "comment.line.double-slash.grpctestify"
        }
      ]
    },
    "section-header": {
      "match": "^(---\\s+)(ADDRESS|ENDPOINT|REQUEST|RESPONSE|ERROR|REQUEST_HEADERS|ASSERTS|EXTRACT|TLS|PROTO|OPTIONS|HEADERS|META)(?:\\s+[^-][^-]*)?(\\s+---)(.*)?$",
      "captures": {
        "1": {
          "name": "punctuation.definition.section.begin.grpctestify"
        },
        "2": {
          "name": "keyword.section.name.grpctestify"
        },
        "3": {
          "name": "punctuation.definition.section.end.grpctestify"
        },
        "4": {
          "name": "meta.section.options.grpctestify"
        }
      }
    },
    "sections": {
      "patterns": [
        {
          "include": "#address-section"
        },
        {
          "include": "#endpoint-section"
        },
        {
          "include": "#request-headers-section"
        },
        {
          "include": "#deprecated-headers-section"
        },
        {
          "include": "#request-section"
        },
        {
          "include": "#response-section"
        },
        {
          "include": "#error-section"
        },
        {
          "include": "#asserts-section"
        },
        {
          "include": "#extract-section"
        },
        {
          "include": "#tls-section"
        },
        {
          "include": "#proto-section"
        },
        {
          "include": "#options-section"
        }
      ]
    },
    "address-section": {
      "begin": "^(---\\s+ADDRESS\\s+---)(.*)?$",
      "beginCaptures": {
        "1": {
          "name": "keyword.section.name.grpctestify"
        },
        "2": {
          "name": "meta.section.options.grpctestify"
        }
      },
      "end": "(?=^---\\s+[A-Z_]+\\s+---|\\z)",
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "match": "^([\\w.-]+:\\d+|https?://[^\\s#]+)(\\s*(#.*|//.*))?$",
          "captures": {
            "1": {
              "name": "string.address.valid.grpctestify"
            },
            "2": {
              "name": "comment.line.grpctestify"
            }
          }
        },
        {
          "match": "^(?!\\s*$)(?!---).+",
          "name": "invalid.illegal.address.grpctestify"
        }
      ]
    },
    "endpoint-section": {
      "begin": "^(---\\s+ENDPOINT\\s+---)(.*)?$",
      "beginCaptures": {
        "1": {
          "name": "keyword.section.name.grpctestify"
        },
        "2": {
          "name": "meta.section.options.grpctestify"
        }
      },
      "end": "(?=^---\\s+[A-Z_]+\\s+---|\\z)",
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "match": "^([\\w.]+\\.)([\\w]+)\\/([\\w.]+)(\\s*(#.*|//.*))?$",
          "captures": {
            "1": {
              "name": "entity.package.grpctestify"
            },
            "2": {
              "name": "entity.service.grpctestify"
            },
            "3": {
              "name": "entity.method.grpctestify"
            },
            "4": {
              "name": "comment.line.grpctestify"
            }
          }
        },
        {
          "match": "^(?!\\s*$)(?!---).+",
          "name": "invalid.illegal.endpoint.grpctestify"
        }
      ]
    },
    "request-headers-section": {
      "begin": "^(---\\s+REQUEST_HEADERS\\s+---)(.*)?$",
      "beginCaptures": {
        "1": {
          "name": "keyword.section.name.grpctestify"
        },
        "2": {
          "name": "meta.section.options.grpctestify"
        }
      },
      "end": "(?=^---\\s+[A-Z_]+\\s+---|\\z)",
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "match": "^([A-Za-z0-9_-]+)(\\s*:\\s*)(.+?)(\\s*(#.*|//.*))?$",
          "captures": {
            "1": {
              "name": "entity.header.key.grpctestify"
            },
            "2": {
              "name": "punctuation.separator.key-value.grpctestify"
            },
            "3": {
              "name": "entity.header.value.grpctestify"
            },
            "4": {
              "name": "comment.line.grpctestify"
            }
          }
        }
      ]
    },
    "deprecated-headers-section": {
      "begin": "^(---\\s+HEADERS\\s+---)(.*)?$",
      "beginCaptures": {
        "1": {
          "name": "invalid.deprecated.section.headers.grpctestify"
        },
        "2": {
          "name": "meta.section.options.grpctestify"
        }
      },
      "end": "(?=^---\\s+[A-Z_]+\\s+---|\\z)",
      "patterns": [
        {
          "include": "#request-headers-section"
        }
      ]
    },
    "request-section": {
      "begin": "^(---\\s+REQUEST\\s+---)(.*)?$",
      "beginCaptures": {
        "1": {
          "name": "keyword.section.name.grpctestify"
        },
        "2": {
          "name": "meta.section.options.grpctestify"
        }
      },
      "end": "(?=^---\\s+[A-Z_]+\\s+---|\\z)",
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "include": "source.json.comments"
        }
      ]
    },
    "response-section": {
      "begin": "^(---\\s+RESPONSE(?:\\s+[^-][^-]*)?\\s+---)(.*)?$",
      "beginCaptures": {
        "1": {
          "name": "keyword.section.name.grpctestify"
        },
        "2": {
          "name": "meta.section.options.grpctestify"
        }
      },
      "end": "(?=^---\\s+[A-Z_]+\\s+---|\\z)",
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "include": "source.json.comments"
        }
      ]
    },
    "error-section": {
      "begin": "^(---\\s+ERROR(?:\\s+[^-][^-]*)?\\s+---)(.*)?$",
      "beginCaptures": {
        "1": {
          "name": "keyword.section.name.grpctestify"
        },
        "2": {
          "name": "meta.section.options.grpctestify"
        }
      },
      "end": "(?=^---\\s+[A-Z_]+\\s+---|\\z)",
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "include": "source.json.comments"
        }
      ]
    },
    "asserts-section": {
      "begin": "^(---\\s+ASSERTS\\s+---)(.*)?$",
      "beginCaptures": {
        "1": {
          "name": "keyword.section.name.grpctestify"
        },
        "2": {
          "name": "meta.section.options.grpctestify"
        }
      },
      "end": "(?=^---\\s+[A-Z_]+\\s+---|\\z)",
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "match": "@([a-zA-Z_][a-zA-Z0-9_]*)\\(",
          "captures": {
            "0": {
              "name": "entity.name.function.plugin.grpctestify"
            }
          }
        },
        {
          "match": "\\b(==|!=|>=|<=|>|<|contains|matches|startsWith|endsWith)\\b",
          "name": "keyword.operator.assertion.grpctestify"
        },
        {
          "match": "\\.[A-Za-z0-9_\\.\\[\\]\\\"]+",
          "name": "variable.language.jq-path.grpctestify"
        }
      ]
    },
    "extract-section": {
      "begin": "^(---\\s+EXTRACT\\s+---)(.*)?$",
      "beginCaptures": {
        "1": {
          "name": "keyword.section.name.grpctestify"
        },
        "2": {
          "name": "meta.section.options.grpctestify"
        }
      },
      "end": "(?=^---\\s+[A-Z_]+\\s+---|\\z)",
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "match": "^([A-Za-z_][A-Za-z0-9_]*)(\\s*:\\s*)(.+)$",
          "captures": {
            "1": {
              "name": "variable.other.extracted-name.grpctestify"
            },
            "2": {
              "name": "punctuation.separator.key-value.grpctestify"
            },
            "3": {
              "name": "meta.jq.expression.grpctestify"
            }
          }
        }
      ]
    },
    "tls-section": {
      "begin": "^(---\\s+TLS\\s+---)(.*)?$",
      "beginCaptures": {
        "1": {
          "name": "keyword.section.name.grpctestify"
        },
        "2": {
          "name": "meta.section.options.grpctestify"
        }
      },
      "end": "(?=^---\\s+[A-Z_]+\\s+---|\\z)",
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "match": "^([A-Za-z_][A-Za-z0-9_]*)(\\s*:\\s*)(.+)$",
          "captures": {
            "1": {
              "name": "support.type.key.tls.grpctestify"
            },
            "2": {
              "name": "punctuation.separator.key-value.grpctestify"
            },
            "3": {
              "name": "string.unquoted.value.grpctestify"
            }
          }
        }
      ]
    },
    "proto-section": {
      "begin": "^(---\\s+PROTO\\s+---)(.*)?$",
      "beginCaptures": {
        "1": {
          "name": "keyword.section.name.grpctestify"
        },
        "2": {
          "name": "meta.section.options.grpctestify"
        }
      },
      "end": "(?=^---\\s+[A-Z_]+\\s+---|\\z)",
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "match": "^([A-Za-z_][A-Za-z0-9_]*)(\\s*:\\s*)(.+)$",
          "captures": {
            "1": {
              "name": "support.type.key.proto.grpctestify"
            },
            "2": {
              "name": "punctuation.separator.key-value.grpctestify"
            },
            "3": {
              "name": "string.unquoted.value.grpctestify"
            }
          }
        }
      ]
    },
    "options-section": {
      "begin": "^(---\\s+OPTIONS\\s+---)(.*)?$",
      "beginCaptures": {
        "1": {
          "name": "keyword.section.name.grpctestify"
        },
        "2": {
          "name": "meta.section.options.grpctestify"
        }
      },
      "end": "(?=^---\\s+[A-Z_]+\\s+---|\\z)",
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "match": "^([A-Za-z_][A-Za-z0-9_-]*)(\\s*:\\s*)(.+)$",
          "captures": {
            "1": {
              "name": "variable.other.option-key.grpctestify"
            },
            "2": {
              "name": "punctuation.separator.key-value.grpctestify"
            },
            "3": {
              "name": "string.unquoted.value.grpctestify"
            }
          }
        }
      ]
    }
  }
}
